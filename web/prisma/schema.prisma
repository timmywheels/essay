generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String         @id @default(cuid())
  name                 String?
  email                String?        @unique
  emailVerified        DateTime?      @map("email_verified")
  image                String?
  username             String?        @unique
  githubUsername       String?        @unique @map("github_username")
  githubInstallationId String?        @map("github_installation_id")
  githubRepo           String?        @map("github_repo")
  cliToken             String?        @unique @map("cli_token")
  createdAt            DateTime       @default(now()) @map("created_at")
  posts                Post[]
  accounts             Account[]
  sessions             Session[]
  settings             UserSettings?
  slugRedirects        SlugRedirect[]

  @@map("users")
}

model UserSettings {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?
  profilePublic     Boolean   @default(true) @map("profile_public")
  showUsername      Boolean   @default(true) @map("show_username")
  showActivityGraph Boolean   @default(true) @map("show_activity_graph")
  showRevisionHistory Boolean @default(false) @map("show_revision_history")
  theme             String    @default("default")
  links             Json?
  customDomain      String?   @unique @map("custom_domain")
  domainVerifiedAt  DateTime? @map("domain_verified_at")
  analyticsId       String?   @map("analytics_id")

  @@index([customDomain])
  @@map("user_settings")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Post {
  id            String         @id @default(cuid())
  title         String
  slug          String
  published     Boolean        @default(false)
  public        Boolean        @default(true)
  publishedAt   DateTime?      @map("published_at")
  views         Int            @default(0)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  userId        String         @map("user_id")
  user          User           @relation(fields: [userId], references: [id])
  slugRedirects SlugRedirect[]

  @@unique([userId, slug])
  @@map("posts")
}

model SlugRedirect {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  oldSlug   String   @map("old_slug")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, oldSlug])
  @@index([postId])
  @@map("slug_redirects")
}
